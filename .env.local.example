# Anthropic API key for Brain Lab features (cognitive load scorer + brain state classifier)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis - powers rate limiting on the Claude API routes (optional locally).
# Without these, rate limiting is skipped with a console warning - fine for dev.
# Create a free Redis DB at https://console.upstash.com/ and copy from its REST API section.
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
